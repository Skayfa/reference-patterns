---
import type { CollectionEntry } from 'astro:content';
import { accentFor, withBase, VERDICT_COLORS } from '../lib/meta';
import { layoutConstellation } from '../lib/constellation';

interface Props {
  patterns: CollectionEntry<'patterns'>[];
}

const { patterns } = Astro.props;

// All geometry is computed at build time, deterministically, and every
// visual constant adapts to the corpus size — see src/lib/constellation.ts.
const layout = layoutConstellation(patterns.map((p) => ({ tags: p.data.tags })));
const { size: SIZE, nodes, edges, dust, animate, gradients } = layout;
---

<figure class="constellation" id="constellation" data-animate={animate ? '1' : undefined}>
  <svg
    viewBox={`0 0 ${SIZE} ${SIZE}`}
    role="img"
    aria-label="The pattern corpus as a growing constellation — each node a pattern, wired by shared tags"
  >
    <defs>
      <filter id="cglow" x="-80%" y="-80%" width="260%" height="260%">
        <feGaussianBlur stdDeviation="2.2" result="blur"></feGaussianBlur>
        <feMerge>
          <feMergeNode in="blur"></feMergeNode>
          <feMergeNode in="SourceGraphic"></feMergeNode>
        </feMerge>
      </filter>
      {
        gradients &&
          edges.map(
            (e, ei) =>
              e.shared.length > 0 && (
                <linearGradient
                  id={`eg-${ei}`}
                  gradientUnits="userSpaceOnUse"
                  x1={nodes[e.a].x}
                  y1={nodes[e.a].y}
                  x2={nodes[e.b].x}
                  y2={nodes[e.b].y}
                >
                  <stop offset="0%" stop-color={accentFor(patterns[e.a].data.language)} />
                  <stop offset="100%" stop-color={accentFor(patterns[e.b].data.language)} />
                </linearGradient>
              )
          )
      }
    </defs>

    <g class="dust" aria-hidden="true">
      {dust.map((s, i) => <circle cx={s.x} cy={s.y} r={s.r} style={`--o: ${s.o}; --i: ${i}`} />)}
    </g>

    <g class="edges">
      {
        edges.map((e, ei) => (
          <path
            class={e.shared.length ? 'synapse shared' : 'synapse'}
            d={e.d}
            data-a={e.a}
            data-b={e.b}
            pathLength="1"
            stroke={e.shared.length ? (gradients ? `url(#eg-${ei})` : 'rgba(242, 239, 233, 0.35)') : undefined}
            stroke-width={e.width}
            style={`--ei: ${ei}`}
          />
        ))
      }
    </g>

    <g class="nodes">
      {
        nodes.map((node, i) => {
          const pattern = patterns[i];
          const accent = accentFor(pattern.data.language);
          const verdict = pattern.data.verdict;
          return (
            <a
              href={withBase(`/${pattern.id}/`)}
              class="cnode"
              data-node={i}
              data-name={pattern.data.name}
              data-degree={node.degree}
              data-tags={node.wiredTags.slice(0, 4).join(', ')}
              data-depth={node.depth.toFixed(2)}
              style={`--i: ${i}; --node: ${accent}`}
              aria-label={`${pattern.data.name} — ${pattern.data.language}/${pattern.data.category}`}
            >
              <circle class="halo" cx={node.x} cy={node.y} r={node.haloR} fill={accent} />
              {verdict && (
                <circle
                  class="vring"
                  cx={node.x}
                  cy={node.y}
                  r={node.r + 3.5}
                  stroke={VERDICT_COLORS[verdict]}
                  stroke-dasharray={verdict === 'trial' ? '2 2.6' : undefined}
                />
              )}
              <circle class="core" cx={node.x} cy={node.y} r={node.r} fill={accent} filter="url(#cglow)" />
              <circle class="hit" cx={node.x} cy={node.y} r={node.hitR} />
              <g
                class="nlabel"
                text-anchor={node.flip ? 'end' : 'start'}
                transform={`translate(${node.flip ? node.x - node.r - 9 : node.x + node.r + 9} ${node.y})`}
              >
                <text y="-1">{pattern.data.name}</text>
                <text class="sub" y="10">
                  {pattern.data.language}/{pattern.data.category}
                </text>
              </g>
            </a>
          );
        })
      }
    </g>
  </svg>
  <figcaption>
    <span class="cap-default">the corpus, growing — each node a pattern, wired by shared tags</span>
    <span class="cap-hint" aria-live="polite"></span>
  </figcaption>
</figure>

<script>
  // Hover intelligence + ambient motion. The layout is baked at build time;
  // this script only illuminates neighborhoods and lets the sky breathe.
  const initConstellation = () => {
    const figure = document.getElementById('constellation');
    if (!figure || figure.dataset.alive) return;
    figure.dataset.alive = '1';

    const svg = figure.querySelector('svg')!;
    const nodes = [...figure.querySelectorAll<SVGAElement>('.cnode')];
    const edges = [...figure.querySelectorAll<SVGPathElement>('.synapse')];
    const capDefault = figure.querySelector<HTMLElement>('.cap-default')!;
    const capHint = figure.querySelector<HTMLElement>('.cap-hint')!;

    const neighborsOf = new Map<string, Set<string>>();
    for (const e of edges) {
      const a = e.dataset.a!;
      const b = e.dataset.b!;
      if (!e.classList.contains('shared')) continue;
      (neighborsOf.get(a) ?? neighborsOf.set(a, new Set()).get(a)!).add(b);
      (neighborsOf.get(b) ?? neighborsOf.set(b, new Set()).get(b)!).add(a);
    }

    const light = (id: string | null) => {
      svg.classList.toggle('focused', id !== null);
      const hood = id === null ? null : (neighborsOf.get(id) ?? new Set());
      for (const n of nodes) {
        const self = n.dataset.node === id;
        n.classList.toggle('src', self);
        n.classList.toggle('lit', self || (hood?.has(n.dataset.node!) ?? false));
      }
      for (const e of edges) {
        e.classList.toggle(
          'lit',
          id !== null && e.classList.contains('shared') && (e.dataset.a === id || e.dataset.b === id)
        );
      }
      const src = id === null ? null : nodes.find((n) => n.dataset.node === id);
      figure.classList.toggle('hinting', !!src);
      if (src) {
        const deg = Number(src.dataset.degree);
        capHint.textContent =
          deg === 0
            ? `${src.dataset.name} — charting its own territory`
            : `${src.dataset.name} ↔ ${deg} pattern${deg > 1 ? 's' : ''} · ${src.dataset.tags}`;
      }
      capDefault.style.opacity = src ? '0' : '';
    };

    for (const n of nodes) {
      n.addEventListener('pointerenter', () => light(n.dataset.node!));
      n.addEventListener('pointerleave', () => light(null));
      n.addEventListener('focus', () => light(n.dataset.node!));
      n.addEventListener('blur', () => light(null));
    }

    // Ambient drift + pointer parallax — hubs sit deep and steady, leaves
    // float more. Everything oscillates around the baked layout, and the
    // synapses re-bend each frame to follow. Only worth its per-frame cost on
    // a sparse sky: past ~150 nodes the layout ships static (hover still works).
    if (!figure.dataset.animate) return;
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    type P = { cs: SVGCircleElement[]; label: SVGGElement; x: number; y: number; flip: boolean; depth: number; phase: number; spd: number };
    const parts: P[] = nodes.map((a, i) => {
      const cs = [...a.querySelectorAll<SVGCircleElement>('circle')];
      const core = a.querySelector<SVGCircleElement>('.core')!;
      return {
        cs,
        label: a.querySelector<SVGGElement>('.nlabel')!,
        x: Number(core.getAttribute('cx')),
        y: Number(core.getAttribute('cy')),
        flip: a.querySelector('.nlabel')!.getAttribute('text-anchor') === 'end',
        depth: Number(a.dataset.depth),
        phase: i * 1.7,
        spd: 0.28 + (i % 5) * 0.05,
      };
    });
    const cur = parts.map((p) => ({ x: p.x, y: p.y }));
    const edgeEnds = edges.map((e) => ({ el: e, a: Number(e.dataset.a), b: Number(e.dataset.b) }));

    let px = 0;
    let py = 0; // parallax target, lerped
    let lx = 0;
    let ly = 0;
    figure.addEventListener('pointermove', (ev) => {
      const r = svg.getBoundingClientRect();
      px = ((ev.clientX - r.left) / r.width - 0.5) * 7;
      py = ((ev.clientY - r.top) / r.height - 0.5) * 7;
    });
    figure.addEventListener('pointerleave', () => {
      px = 0;
      py = 0;
    });

    let running = false;
    let raf = 0;
    const tick = (t: number) => {
      lx += (px - lx) * 0.06;
      ly += (py - ly) * 0.06;
      const s = t / 1000;
      parts.forEach((p, i) => {
        const x = p.x + Math.sin(s * p.spd + p.phase) * 2.4 * p.depth + lx * p.depth;
        const y = p.y + Math.cos(s * p.spd * 0.9 + p.phase * 1.3) * 2.4 * p.depth + ly * p.depth;
        cur[i].x = x;
        cur[i].y = y;
        for (const c of p.cs) {
          c.setAttribute('cx', String(x));
          c.setAttribute('cy', String(y));
        }
        const r = Number(p.cs.find((c) => c.classList.contains('core'))!.getAttribute('r'));
        p.label.setAttribute('transform', `translate(${p.flip ? x - r - 9 : x + r + 9} ${y})`);
      });
      for (const { el, a, b } of edgeEnds) {
        const A = cur[a];
        const B = cur[b];
        const dx = B.x - A.x;
        const dy = B.y - A.y;
        const len = Math.max(Math.hypot(dx, dy), 0.01);
        const ei = Number((el.style.getPropertyValue('--ei') || '0').trim());
        const bow = (ei % 2 === 0 ? 1 : -1) * Math.min(len * 0.16, 16);
        const mx = (A.x + B.x) / 2 + (-dy / len) * bow;
        const my = (A.y + B.y) / 2 + (dx / len) * bow;
        el.setAttribute('d', `M ${A.x} ${A.y} Q ${mx} ${my} ${B.x} ${B.y}`);
      }
      raf = requestAnimationFrame(tick);
    };
    const setRunning = (on: boolean) => {
      if (on === running) return;
      running = on;
      if (on) raf = requestAnimationFrame(tick);
      else cancelAnimationFrame(raf);
    };
    new IntersectionObserver(([entry]) => setRunning(entry.isIntersecting && !document.hidden)).observe(svg);
    document.addEventListener('visibilitychange', () =>
      setRunning(!document.hidden && svg.getBoundingClientRect().bottom > 0)
    );
  };

  initConstellation();
  document.addEventListener('astro:page-load', initConstellation);
</script>
