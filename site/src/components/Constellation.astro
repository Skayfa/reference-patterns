---
import type { CollectionEntry } from 'astro:content';
import { accentFor, withBase, VERDICT_COLORS } from '../lib/meta';

interface Props {
  patterns: CollectionEntry<'patterns'>[];
}

const { patterns } = Astro.props;

const SIZE = 360;
const center = SIZE / 2;

// Deterministic PRNG — the layout must be identical on every build.
const mulberry32 = (seed: number) => () => {
  seed |= 0;
  seed = (seed + 0x6d2b79f5) | 0;
  let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
  t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
  return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
};
const rand = mulberry32(2026);

// Edges: patterns sharing tags attract each other; more shared tags = a
// stronger spring. Isolated nodes get a weak chain link so nothing floats off.
type Edge = { a: number; b: number; shared: string[]; weight: number };
const edges: Edge[] = [];
for (let a = 0; a < patterns.length; a++) {
  for (let b = a + 1; b < patterns.length; b++) {
    const shared = patterns[a].data.tags.filter((t) => patterns[b].data.tags.includes(t));
    if (shared.length) edges.push({ a, b, shared, weight: 1 + 0.5 * (shared.length - 1) });
  }
  if (a > 0 && !edges.some((e) => e.b === a && e.shared.length)) {
    edges.push({ a: a - 1, b: a, shared: [], weight: 0.3 });
  }
}

const degree = patterns.map(
  (_, i) => edges.filter((e) => e.shared.length && (e.a === i || e.b === i)).length
);

// Force-directed layout (Fruchterman–Reingold), run once at build time:
// repulsion between every pair, spring attraction along edges, gravity to the
// center. Seeded golden-angle start; clusters emerge from the tag graph.
const GOLDEN_ANGLE = 2.39996;
const pos = patterns.map((_, i) => {
  const r = 26 * Math.sqrt(i + 0.5);
  return {
    x: center + r * Math.cos(i * GOLDEN_ANGLE) + (rand() - 0.5) * 8,
    y: center + r * Math.sin(i * GOLDEN_ANGLE) + (rand() - 0.5) * 8,
  };
});

const n = patterns.length;
const k = Math.sqrt((SIZE * SIZE) / Math.max(n, 1)) * 0.95;
const ITER = 300;
for (let it = 0; it < ITER; it++) {
  const temp = 0.1 * SIZE * (1 - it / ITER) + 0.5;
  const disp = pos.map(() => ({ x: 0, y: 0 }));

  for (let a = 0; a < n; a++) {
    for (let b = a + 1; b < n; b++) {
      let dx = pos[a].x - pos[b].x;
      let dy = pos[a].y - pos[b].y;
      let d = Math.hypot(dx, dy);
      if (d < 0.01) {
        dx = rand() - 0.5;
        dy = rand() - 0.5;
        d = Math.hypot(dx, dy);
      }
      const f = (k * k) / d;
      disp[a].x += (dx / d) * f;
      disp[a].y += (dy / d) * f;
      disp[b].x -= (dx / d) * f;
      disp[b].y -= (dy / d) * f;
    }
  }

  for (const e of edges) {
    const dx = pos[e.a].x - pos[e.b].x;
    const dy = pos[e.a].y - pos[e.b].y;
    const d = Math.max(Math.hypot(dx, dy), 0.01);
    const f = ((d * d) / k) * e.weight;
    disp[e.a].x -= (dx / d) * f;
    disp[e.a].y -= (dy / d) * f;
    disp[e.b].x += (dx / d) * f;
    disp[e.b].y += (dy / d) * f;
  }

  for (let i = 0; i < n; i++) {
    disp[i].x -= (pos[i].x - center) * 0.03;
    disp[i].y -= (pos[i].y - center) * 0.03;
    const d = Math.max(Math.hypot(disp[i].x, disp[i].y), 0.01);
    pos[i].x += (disp[i].x / d) * Math.min(d, temp);
    pos[i].y += (disp[i].y / d) * Math.min(d, temp);
  }
}

// De-overlap pass: the drift animation needs breathing room around each node.
const MIN_GAP = 30;
for (let pass = 0; pass < 60; pass++) {
  let moved = false;
  for (let a = 0; a < n; a++) {
    for (let b = a + 1; b < n; b++) {
      const dx = pos[b].x - pos[a].x;
      const dy = pos[b].y - pos[a].y;
      const d = Math.max(Math.hypot(dx, dy), 0.01);
      if (d < MIN_GAP) {
        const push = (MIN_GAP - d) / 2;
        pos[a].x -= (dx / d) * push;
        pos[a].y -= (dy / d) * push;
        pos[b].x += (dx / d) * push;
        pos[b].y += (dy / d) * push;
        moved = true;
      }
    }
  }
  if (!moved) break;
}

// Fit the settled layout into the viewBox with padding for halos and labels.
const PAD = 34;
const xs = pos.map((p) => p.x);
const ys = pos.map((p) => p.y);
const [minX, maxX] = [Math.min(...xs), Math.max(...xs)];
const [minY, maxY] = [Math.min(...ys), Math.max(...ys)];
const scale = Math.min(
  (SIZE - PAD * 2) / Math.max(maxX - minX, 1),
  (SIZE - PAD * 2) / Math.max(maxY - minY, 1)
);
for (const p of pos) {
  p.x = PAD + (p.x - minX) * scale + (SIZE - PAD * 2 - (maxX - minX) * scale) / 2;
  p.y = PAD + (p.y - minY) * scale + (SIZE - PAD * 2 - (maxY - minY) * scale) / 2;
}

const nodes = patterns.map((p, i) => {
  const wiredTags = [
    ...new Set(edges.filter((e) => (e.a === i || e.b === i) && e.shared.length).flatMap((e) => e.shared)),
  ];
  return {
    pattern: p,
    x: pos[i].x,
    y: pos[i].y,
    r: 4.5 + Math.min(degree[i], 5) * 0.8,
    accent: accentFor(p.data.language),
    verdict: p.data.verdict,
    // Labels flip side near the right edge so they never clip.
    flip: pos[i].x > SIZE * 0.62,
    depth: 1 / (1 + degree[i] * 0.35),
    wiredTags,
    i,
  };
});

// Curved synapses: a quadratic Bézier bowed perpendicular to the chord, with a
// per-edge gradient blending the two node accents.
const edgePaths = edges.map((e, ei) => {
  const a = nodes[e.a];
  const b = nodes[e.b];
  const mx = (a.x + b.x) / 2;
  const my = (a.y + b.y) / 2;
  const dx = b.x - a.x;
  const dy = b.y - a.y;
  const len = Math.max(Math.hypot(dx, dy), 0.01);
  const bow = ((ei % 2 === 0 ? 1 : -1) * Math.min(len * 0.16, 16));
  return {
    ...e,
    ei,
    d: `M ${a.x.toFixed(1)} ${a.y.toFixed(1)} Q ${(mx + (-dy / len) * bow).toFixed(1)} ${(my + (dx / len) * bow).toFixed(1)} ${b.x.toFixed(1)} ${b.y.toFixed(1)}`,
    width: e.shared.length ? 1.1 + Math.min(e.shared.length, 3) * 0.45 : 0.7,
  };
});

// Star dust behind the graph — the constellation lives in a sky.
const dust = Array.from({ length: 46 }, (_, i) => {
  const angle = rand() * Math.PI * 2;
  const radius = Math.sqrt(rand()) * (SIZE / 2 - 8);
  return {
    x: center + radius * Math.cos(angle),
    y: center + radius * Math.sin(angle),
    r: 0.4 + rand() * 0.8,
    o: 0.05 + rand() * 0.14,
    i,
  };
});
---

<figure class="constellation" id="constellation">
  <svg
    viewBox={`0 0 ${SIZE} ${SIZE}`}
    role="img"
    aria-label="The pattern corpus as a growing constellation — each node a pattern, wired by shared tags"
  >
    <defs>
      <filter id="cglow" x="-80%" y="-80%" width="260%" height="260%">
        <feGaussianBlur stdDeviation="2.2" result="blur"></feGaussianBlur>
        <feMerge>
          <feMergeNode in="blur"></feMergeNode>
          <feMergeNode in="SourceGraphic"></feMergeNode>
        </feMerge>
      </filter>
      {
        edgePaths
          .filter((e) => e.shared.length)
          .map((e) => (
            <linearGradient
              id={`eg-${e.ei}`}
              gradientUnits="userSpaceOnUse"
              x1={nodes[e.a].x}
              y1={nodes[e.a].y}
              x2={nodes[e.b].x}
              y2={nodes[e.b].y}
            >
              <stop offset="0%" stop-color={nodes[e.a].accent} />
              <stop offset="100%" stop-color={nodes[e.b].accent} />
            </linearGradient>
          ))
      }
    </defs>

    <g class="dust" aria-hidden="true">
      {dust.map((s) => <circle cx={s.x} cy={s.y} r={s.r} style={`--o: ${s.o}; --i: ${s.i}`} />)}
    </g>

    <g class="edges">
      {
        edgePaths.map((e) => (
          <path
            class={e.shared.length ? 'synapse shared' : 'synapse'}
            d={e.d}
            data-a={e.a}
            data-b={e.b}
            pathLength="1"
            stroke={e.shared.length ? `url(#eg-${e.ei})` : undefined}
            stroke-width={e.width}
            style={`--ei: ${e.ei}`}
          />
        ))
      }
    </g>

    <g class="nodes">
      {
        nodes.map((node) => (
          <a
            href={withBase(`/${node.pattern.id}/`)}
            class="cnode"
            data-node={node.i}
            data-name={node.pattern.data.name}
            data-degree={degree[node.i]}
            data-tags={node.wiredTags.slice(0, 4).join(', ')}
            data-depth={node.depth.toFixed(2)}
            style={`--i: ${node.i}; --node: ${node.accent}`}
            aria-label={`${node.pattern.data.name} — ${node.pattern.data.language}/${node.pattern.data.category}`}
          >
            <circle class="halo" cx={node.x} cy={node.y} r={node.r + 7} fill={node.accent} />
            {node.verdict && (
              <circle
                class="vring"
                cx={node.x}
                cy={node.y}
                r={node.r + 3.5}
                stroke={VERDICT_COLORS[node.verdict]}
                stroke-dasharray={node.verdict === 'trial' ? '2 2.6' : undefined}
              />
            )}
            <circle class="core" cx={node.x} cy={node.y} r={node.r} fill={node.accent} filter="url(#cglow)" />
            <circle class="hit" cx={node.x} cy={node.y} r={Math.max(node.r + 9, 14)} />
            <g
              class="nlabel"
              text-anchor={node.flip ? 'end' : 'start'}
              transform={`translate(${node.flip ? node.x - node.r - 9 : node.x + node.r + 9} ${node.y})`}
            >
              <text y="-1">{node.pattern.data.name}</text>
              <text class="sub" y="10">
                {node.pattern.data.language}/{node.pattern.data.category}
              </text>
            </g>
          </a>
        ))
      }
    </g>
  </svg>
  <figcaption>
    <span class="cap-default">the corpus, growing — each node a pattern, wired by shared tags</span>
    <span class="cap-hint" aria-live="polite"></span>
  </figcaption>
</figure>

<script>
  // Hover intelligence + ambient motion. The layout is baked at build time;
  // this script only illuminates neighborhoods and lets the sky breathe.
  const initConstellation = () => {
    const figure = document.getElementById('constellation');
    if (!figure || figure.dataset.alive) return;
    figure.dataset.alive = '1';

    const svg = figure.querySelector('svg')!;
    const nodes = [...figure.querySelectorAll<SVGAElement>('.cnode')];
    const edges = [...figure.querySelectorAll<SVGPathElement>('.synapse')];
    const capDefault = figure.querySelector<HTMLElement>('.cap-default')!;
    const capHint = figure.querySelector<HTMLElement>('.cap-hint')!;

    const neighborsOf = new Map<string, Set<string>>();
    for (const e of edges) {
      const a = e.dataset.a!;
      const b = e.dataset.b!;
      if (!e.classList.contains('shared')) continue;
      (neighborsOf.get(a) ?? neighborsOf.set(a, new Set()).get(a)!).add(b);
      (neighborsOf.get(b) ?? neighborsOf.set(b, new Set()).get(b)!).add(a);
    }

    const light = (id: string | null) => {
      svg.classList.toggle('focused', id !== null);
      const hood = id === null ? null : (neighborsOf.get(id) ?? new Set());
      for (const n of nodes) {
        const self = n.dataset.node === id;
        n.classList.toggle('src', self);
        n.classList.toggle('lit', self || (hood?.has(n.dataset.node!) ?? false));
      }
      for (const e of edges) {
        e.classList.toggle(
          'lit',
          id !== null && e.classList.contains('shared') && (e.dataset.a === id || e.dataset.b === id)
        );
      }
      const src = id === null ? null : nodes.find((n) => n.dataset.node === id);
      figure.classList.toggle('hinting', !!src);
      if (src) {
        const deg = Number(src.dataset.degree);
        capHint.textContent =
          deg === 0
            ? `${src.dataset.name} — charting its own territory`
            : `${src.dataset.name} ↔ ${deg} pattern${deg > 1 ? 's' : ''} · ${src.dataset.tags}`;
      }
      capDefault.style.opacity = src ? '0' : '';
    };

    for (const n of nodes) {
      n.addEventListener('pointerenter', () => light(n.dataset.node!));
      n.addEventListener('pointerleave', () => light(null));
      n.addEventListener('focus', () => light(n.dataset.node!));
      n.addEventListener('blur', () => light(null));
    }

    // Ambient drift + pointer parallax — hubs sit deep and steady, leaves
    // float more. Everything oscillates around the baked layout, and the
    // synapses re-bend each frame to follow.
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    type P = { cs: SVGCircleElement[]; label: SVGGElement; x: number; y: number; flip: boolean; depth: number; phase: number; spd: number };
    const parts: P[] = nodes.map((a, i) => {
      const cs = [...a.querySelectorAll<SVGCircleElement>('circle')];
      const core = a.querySelector<SVGCircleElement>('.core')!;
      return {
        cs,
        label: a.querySelector<SVGGElement>('.nlabel')!,
        x: Number(core.getAttribute('cx')),
        y: Number(core.getAttribute('cy')),
        flip: a.querySelector('.nlabel')!.getAttribute('text-anchor') === 'end',
        depth: Number(a.dataset.depth),
        phase: i * 1.7,
        spd: 0.28 + (i % 5) * 0.05,
      };
    });
    const cur = parts.map((p) => ({ x: p.x, y: p.y }));
    const edgeEnds = edges.map((e) => ({ el: e, a: Number(e.dataset.a), b: Number(e.dataset.b) }));

    let px = 0;
    let py = 0; // parallax target, lerped
    let lx = 0;
    let ly = 0;
    figure.addEventListener('pointermove', (ev) => {
      const r = svg.getBoundingClientRect();
      px = ((ev.clientX - r.left) / r.width - 0.5) * 7;
      py = ((ev.clientY - r.top) / r.height - 0.5) * 7;
    });
    figure.addEventListener('pointerleave', () => {
      px = 0;
      py = 0;
    });

    let running = false;
    let raf = 0;
    const tick = (t: number) => {
      lx += (px - lx) * 0.06;
      ly += (py - ly) * 0.06;
      const s = t / 1000;
      parts.forEach((p, i) => {
        const x = p.x + Math.sin(s * p.spd + p.phase) * 2.4 * p.depth + lx * p.depth;
        const y = p.y + Math.cos(s * p.spd * 0.9 + p.phase * 1.3) * 2.4 * p.depth + ly * p.depth;
        cur[i].x = x;
        cur[i].y = y;
        for (const c of p.cs) {
          c.setAttribute('cx', String(x));
          c.setAttribute('cy', String(y));
        }
        const r = Number(p.cs.find((c) => c.classList.contains('core'))!.getAttribute('r'));
        p.label.setAttribute('transform', `translate(${p.flip ? x - r - 9 : x + r + 9} ${y})`);
      });
      for (const { el, a, b } of edgeEnds) {
        const A = cur[a];
        const B = cur[b];
        const dx = B.x - A.x;
        const dy = B.y - A.y;
        const len = Math.max(Math.hypot(dx, dy), 0.01);
        const ei = Number((el.style.getPropertyValue('--ei') || '0').trim());
        const bow = (ei % 2 === 0 ? 1 : -1) * Math.min(len * 0.16, 16);
        const mx = (A.x + B.x) / 2 + (-dy / len) * bow;
        const my = (A.y + B.y) / 2 + (dx / len) * bow;
        el.setAttribute('d', `M ${A.x} ${A.y} Q ${mx} ${my} ${B.x} ${B.y}`);
      }
      raf = requestAnimationFrame(tick);
    };
    const setRunning = (on: boolean) => {
      if (on === running) return;
      running = on;
      if (on) raf = requestAnimationFrame(tick);
      else cancelAnimationFrame(raf);
    };
    new IntersectionObserver(([entry]) => setRunning(entry.isIntersecting && !document.hidden)).observe(svg);
    document.addEventListener('visibilitychange', () =>
      setRunning(!document.hidden && svg.getBoundingClientRect().bottom > 0)
    );
  };

  initConstellation();
  document.addEventListener('astro:page-load', initConstellation);
</script>
